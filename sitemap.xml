---
layout: null
permalink: /sitemap.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {% assign static_pages = site.pages | where_exp: "item", "item.url != '/404.html'" %}
  {% for item in static_pages %}
    {% if item.url contains '.xml' or item.url contains '.txt' or item.url contains '.webmanifest' %}
      {% continue %}
    {% endif %}
  <url>
    <loc>{{ site.url }}{{ item.url }}</loc>
  </url>
  {% endfor %}
  {% for item in site.videos %}
  <url>
    <loc>{{ site.url }}{{ item.url }}</loc>
  </url>
  {% endfor %}
  {% for item in site.articles %}
  <url>
    <loc>{{ site.url }}{{ item.url }}</loc>
  </url>
  {% endfor %}
</urlset>
