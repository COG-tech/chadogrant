---
layout: null
permalink: /sitemap.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {% assign static_pages = site.pages | where_exp: "item", "item.url != '/404.html'" %}
  {% for item in static_pages %}
    {% if item.url contains '.xml' or item.url contains '.txt' or item.url contains '.json' or item.url contains '.webmanifest' or item.url contains '.css' or item.url contains '.js' or item.url contains '/assets/' %}
      {% continue %}
    {% endif %}
    {% include sitemap-entry.xml item=item %}
  {% endfor %}
  {% assign books = site.books | sort: "order" %}
  {% for item in books %}
    {% include sitemap-entry.xml item=item %}
  {% endfor %}
  {% for item in site.videos %}
    {% include sitemap-entry.xml item=item %}
  {% endfor %}
  {% for item in site.articles %}
    {% include sitemap-entry.xml item=item %}
  {% endfor %}
</urlset>
